{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "h5i hook claude sync",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Read"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "h5i hook session-start",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "h5i hook claude finish",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "h5i hook claude prompt",
            "type": "command"
          }
        ]
      }
    ]
  }
}